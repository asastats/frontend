# Infrastructure-level variables for the Ansible deployment.
# Create three copies of this file and fill them with the related values:
#   .env.testing
#   .env.production
#   .env.ci
#
# Application secrets (ASASTATS_API_KEY, SECRET_KEY, ALGOD/INDEXER, etc.)
# live in the Django project's own env files: ../website/.env.<environment>
#
# Commented-out variables have default values.
# Please use SECRET_KEY without comma (,) to prevent issues in SupervisorD configuration
#
GITHUB_USER=myusername
REPO_NAME=asastats
ADMIN_USER=myusername
ADMIN_EMAIL=myusername@example.com
WEBAPP_USER=mywebappuser
REDIS_PASSWORD=redispwd
SITE_NAME=tracker.example.com
DATABASE_USER=website_db
DATABASE_NAME=website_db
DATABASE_PASSWORD=postgres
SECRET_KEY=my_secret
# Port for the dedicated web-cache Redis instance (defaults to 6380).
# This is the app's REDIS_PORT_LOCAL; do NOT point it at an existing 6379 server.
# REDIS_PORT_LOCAL=6380
# PUBLIC_KEY_LOCAL_PATH="~/.ssh/id_rsa.pub"
# WEBAPP_GROUP=webapps

# Set true ONLY on a host that also runs the closed backend (ASA Stats
# liveserver). Keeps the web cache on 6380 so it can't collide with the
# backend's 6379 replica. Forkers leave this unset/false.
# BACKEND_COLOCATED=false
