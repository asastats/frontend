# Infrastructure-level variables for the Ansible deployment.
# Create three copies of this file and fill them with the related values:
#   .env.testing
#   .env.production
#   .env.ci
#
# Application secrets (ASASTATS_API_KEY, SECRET_KEY, ALGOD/INDEXER, etc.)
# live in the Django project's own env files: ../asastats/.env.<environment>
#
# Commented-out variables have default values.
#
GITHUB_USER=myusername
REPO_NAME=asastats
ADMIN_USER=myusername
ADMIN_EMAIL=myusername@example.com
WEBAPP_USER=mywebappuser
REDIS_PASSWORD=myredispassword
SITE_NAME=tracker.example.com
DATABASE_USER=postgres
DATABASE_NAME=asastats_db
DATABASE_PASSWORD=postgres
SECRET_KEY=my_secret
# PUBLIC_KEY_LOCAL_PATH="~/.ssh/id_rsa.pub"
# WEBAPP_GROUP=webapps
