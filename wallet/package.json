{
  "name": "wallet-frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:docs": "typedoc",
    "preview": "vite preview",
    "test": "node --no-warnings node_modules/.bin/jest --config jest.config.cjs",
    "test:watch": "node --no-warnings node_modules/.bin/jest --config jest.config.cjs --watch",
    "test:coverage": "node --no-warnings node_modules/.bin/jest --config jest.config.cjs --coverage",
    "test:all": "node --no-warnings node_modules/.bin/jest --config jest.config.cjs --coverage --verbose",
    "test:ci": "jest --config jest.config.cjs --coverage --coverageReporters=lcov --coverageReporters=text --coverageReporters=html"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "esbuild": "^0.28.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.12.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vite-plugin-node-polyfills": "0.28.0"
  },
  "dependencies": {
    "@blockshake/defly-connect": "^1.2.1",
    "@folks-router/js-sdk": "^0.5.1",
    "@perawallet/connect": "^1.5.2",
    "@txnlab/use-wallet": "^4.6.0",
    "@walletconnect/ethereum-provider": "^2.23.9",
    "algosdk": "^3.6.0",
    "lute-connect": "^1.7.0",
    "viem": "^2.52.2"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "@tootallnate/once": ">=3.0.1",
    "bn.js": ">=4.12.3",
    "algosdk": "^3.6.0"
  }
}
