{
  "@context": "http://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "{{ WEBSITE_NAME }}",
      "url": "{{ WEBSITE_URL }}",
      "@id": "{{ WEBSITE_URL }}/#site",
      "description": "{{ WEBSITE_NAME }} evaluates and presents ASA and NFT price information on the Algorand blockchain. Portfolio Tracker, API and Feature-Driven Development.",
      "publisher": {
        "@type": "Organization",
        "@id": "{{ WEBSITE_URL }}/#org",
        "name": "{{ WEBSITE_NAME }}"
      },
      "hasPart": [
        {
          "@type": "WebPage",
          "name": "About",
          "url": "{{ WEBSITE_URL }}/about/",
          "@id": "{{ WEBSITE_URL }}/#about",
          "description": "{{ WEBSITE_NAME }} concept, goals and author/team/DAO"
        },
        {
          "@type": "WebPage",
          "name": "Tokenomics",
          "url": "{{ WEBSITE_URL }}/tokenomics/",
          "@id": "{{ WEBSITE_URL }}/#tokenomics",
          "description": "{{ WEBSITE_NAME }} Token metrics"
        },
        {
          "@type": "WebPage",
          "name": "Subscriptions",
          "url": "{{ WEBSITE_URL }}/subscriptions/",
          "@id": "{{ WEBSITE_URL }}/#subscriptions",
          "description": "{{ WEBSITE_NAME }} subscription model"
        },
        {
          "@type": "WebPage",
          "name": "FAQ page",
          "url": "{{ WEBSITE_URL }}/faq/",
          "@id": "{{ WEBSITE_URL }}/#faq",
          "description": "Frequently asked questions about {{ WEBSITE_NAME }} project and token"
        },
        {
          "@type": "WebPage",
          "name": "Features",
          "url": "{{ WEBSITE_URL }}/features/",
          "@id": "{{ WEBSITE_URL }}/#features",
          "description": "{{ WEBSITE_NAME }} features"
        },
        {
          "@type": "WebPage",
          "name": "Disclaimer",
          "url": "{{ WEBSITE_URL }}/disclaimer/",
          "@id": "{{ WEBSITE_URL }}/#disclaimer",
          "description": "Disclaimer for the {{ WEBSITE_URL }} website"
        },
        {
          "@type": "WebPage",
          "name": "{{ WEBSITE_NAME }} Mobile Privacy Policy",
          "url": "{{ WEBSITE_URL }}/asm-privacy/",
          "@id": "{{ WEBSITE_URL }}/#asm-privacy",
          "description": "Privacy Policy for the {{ WEBSITE_NAME }} Mobile application"
        }
      ]
    },
    {
      "@type": "Organization",
      "name": "{{ WEBSITE_NAME }}",
      "description": "Responsible for development of the {{ WEBSITE_NAME }} project",
      "@id": "{{ WEBSITE_URL }}/#org",
      "image": "{{ WEBSITE_URL }}/logo.png",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ WEBSITE_URL }}/icon.png",
        "caption": "{{ WEBSITE_NAME }} icon logo",
        "width": 512,
        "height": 512
      },
      "url": "{{ WEBSITE_URL }}",
      "sameAs": [
        "https://x.com/{{ X_HANDLE }}",
        "https://www.reddit.com/r/{{ SUBREDDIT_NAME }}"
      ]
    }
  ]
}