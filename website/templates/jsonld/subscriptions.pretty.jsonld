{
  "@context": "http://schema.org",
  "@type": "WebPage",
  "name": "Subscriptions",
  "url": "{{ WEBSITE_URL }}/subscriptions/",
  "@id": "{{ WEBSITE_URL }}/#subscriptions",
  "description": "{{ WEBSITE_NAME }} Subscription plans - subscribe to one of our tiers to use the {{ WEBSITE_NAME }} advanced features.",
  "isPartOf":{
      "@type": "WebSite",
      "@id":"{{ WEBSITE_URL }}/#site",
      "name": "{{ WEBSITE_NAME }}"
  },
  "publisher": {
      "@type": "Organization",
      "@id": "{{ WEBSITE_URL }}/#org",
      "name": "{{ WEBSITE_NAME }}"
  }
}