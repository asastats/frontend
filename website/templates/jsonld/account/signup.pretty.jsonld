{
    "@context": "http://schema.org",
    "@type": "WebPage",
    "name": "Sign up",
    "url": "{{ WEBSITE_URL }}/accounts/signup/",
    "@id": "{{ WEBSITE_URL }}/#signup",
    "description": "Sign up for a {{ WEBSITE_NAME }} account by an email and password or by connecting a social media provider",
    "isPartOf":{
        "@type": "WebSite",
        "@id":"{{ WEBSITE_URL }}/#site",
        "name": "{{ WEBSITE_NAME }}"
    },
    "publisher": {
        "@type": "Organization",
        "@id": "{{ WEBSITE_URL }}/#org",
        "name": "www.{{ WEBSITE_NAME }}.com"
    },
    "hasPart": [
        {
            "@type": "WebPage",
            "name": "Log in page",
            "url": "{{ WEBSITE_URL }}/accounts/login/",
            "@id": "{{ WEBSITE_URL }}/#login",
            "description": "You can log in to your {{ WEBSITE_NAME }} account either with your email and password or by a connected social media provider."
        },
        {
            "@type": "WebPage",
            "name": "Reset password page",
            "url": "{{ WEBSITE_URL }}/accounts/password/reset/",
            "@id": "{{ WEBSITE_URL }}/#password-reset",
            "description": "You can initiate your account password reset on this page."
        }
    ]
}