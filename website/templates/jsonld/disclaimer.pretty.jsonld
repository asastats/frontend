{
  "@context": "http://schema.org",
  "@type": "WebPage",
  "name": "Disclaimer",
  "url": "{{ WEBSITE_URL }}/disclaimer/",
  "@id": "{{ WEBSITE_URL }}/#disclaimer",
  "description": "Disclaimer for the {{ WEBSITE_URL }} website",
  "isPartOf":{
      "@type": "WebSite",
      "@id":"{{ WEBSITE_URL }}/#site",
      "name": "{{ WEBSITE_NAME }}"
  },
  "publisher": {
      "@type": "Organization",
      "@id": "{{ WEBSITE_URL }}/#org",
      "name": "{{ WEBSITE_NAME }}"
  }
}