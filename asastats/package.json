{
  "jest": {
    "testEnvironment": "jsdom",
    "verbose": true,
    "collectCoverage": true,
    "coverageDirectory": "<rootDir>/javascript_tests/coverage",
    "collectCoverageFrom": [
      "<rootDir>/static/js/*.js",
      "!<rootDir>/static/js/**.min*.js",
      "!<rootDir>/static/js/websocketbridge.js",
      "!<rootDir>/javascript_tests/coverage/**"
    ],
    "coverageReporters": [
      "lcov",
      "text"
    ],
    "setupFiles": [
      "jest-localstorage-mock",
      "<rootDir>/javascript_tests/test_helpers.js"
    ]
  },
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:coverage:verbose": "jest --coverage --verbose",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "jest-localstorage-mock": "^2.4.26",
    "jest-environment-jsdom": "^29.7.0",
    "canvas": "^2.5.0",
    "jest": "^29.7.0",
    "mock-socket": "^9.3.1"
  }
}
