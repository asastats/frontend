# ===========================================================================
# asastats (open source) — environment template
# The closed engine / api.asastats.com project has its OWN .env (see §REDIS).
# ===========================================================================

# --- Django ---
SECRET_KEY=
SIMPLE_JWT_KEY=                     # ROTATED — never reuse the old hardcoded value

# --- Database (this app's own Postgres: users, profiles, bundles) ---
DATABASE_NAME=
DATABASE_USER=
DATABASE_PASSWORD=
DATABASE_HOST=localhost             # was hardcoded in base.py; now env-driven
DATABASE_PORT=5432
PGPASSFILE=/home/youruser/.pgpass   # optional; libpq passfile path (host-specific)

# --- ASA Stats backend (the engine boundary over HTTP) ---
ASASTATS_API_URL=https://api.asastats.com
ASASTATS_API_KEY=                   # this deployment's credential -> Gate A
ASASTATS_API_TIMEOUT=30

# --- Algorand access (public nodes for forks; private for the main site) ---
# Still needed by the OPEN app to read the on-chain permission dApp (Gate B),
# NOT for portfolio data.
ALGOD_URL=https://mainnet-api.algonode.cloud
ALGOD_TOKEN=
INDEXER_URL=https://mainnet-idx.algonode.cloud
INDEXER_TOKEN=

# --- This deployment's local cache / Huey broker (NOT the engine's Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- OAuth / integrations (unchanged) ---
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DISCORD_APPLICATION_ID=
DISCORD_SECRET=
DISCORD_PUBLIC_KEY=
TWITTER_CLIENT_ID=
TWITTER_SECRET=
REDDIT_CLIENT_ID=
REDDIT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_SECRET=
WIDGETS_API_TOKEN=
